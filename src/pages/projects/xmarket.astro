---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Projects - xMarket" description="Project page for xMarket.">
  <header class="xmarket-hero">
    <h1>xMarket</h1>
  </header>
  <section class="bg-part bg-part--with-hero">
    <h2>Contexte</h2>
    <p>Project details coming soon.</p>
    <h2>L'application</h2>
    <p>Project details coming soon.</p>
    <h2>Infrastructure & choix</h2>
    <p>Project details coming soon.</p>
  </section>
</Layout>

<style>
  .xmarket-hero {
    position: relative;
    width: 100%;
    height: 50svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3rem;
    background:
      linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)),
      url("/projets/xmarket-1.png") center / cover no-repeat;
    z-index: 1;
  }

  .bg-part--with-hero {
    min-height: auto;
    padding-top: 2.5rem;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 900px) {
    .bg-part--with-hero {
      padding-top: 3rem;
    }
  }
</style>
